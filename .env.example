# Runtime delivery of short-lived TURN credentials. The endpoint may return
# either an RTCIceServer[] or { "iceServers": RTCIceServer[] }.
VITE_ICE_SERVERS_URL=https://example.com/api/rtc/ice-servers

# Optional static TURN fallback for private/self-hosted environments.
# Do not commit real credentials.
VITE_TURN_URLS=turn:turn.example.com:3478?transport=udp,turns:turn.example.com:5349?transport=tcp
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
VITE_ICE_TRANSPORT_POLICY=all

# Room discovery uses MQTT over secure WebSockets. Leave URLs empty to use
# Trystero's public defaults.
VITE_SIGNALING_APP_ID=digitable-chat
VITE_SIGNALING_RELAY_URLS=wss://mqtt.example.com/mqtt
VITE_SIGNALING_RELAY_REDUNDANCY=3

# File transfer is independent from chat/call signaling and may use a
# WebTorrent tracker. Leave empty to use secure-file-transfer defaults.
VITE_FILE_TRACKER_URLS=
VITE_STREAMSAVER_URL=

VITE_GITHUB_REPO=https://github.com/digitable-lol/chat
